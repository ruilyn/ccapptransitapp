# ============================================================
# Smart Route Guardian – Environment Variables
# ============================================================
# Copy this file to .env and fill in real values before running.

# --------------------------------------------------------------
# MTA API Key (required for live subway feeds)
# Get a free key at: https://api.mta.info/#/signup
# --------------------------------------------------------------
MTA_API_KEY=your_mta_api_key_here

# --------------------------------------------------------------
# MTA Bus Time API Key (optional – enables live Bx15 bus data)
# Same developer portal as above.
# If not set, the Bx15 route will show "No bus data" status.
# --------------------------------------------------------------
MTA_BUS_API_KEY=your_mta_bus_api_key_here

# --------------------------------------------------------------
# Feed URLs (defaults shown – only change if MTA restructures)
# --------------------------------------------------------------
MTA_FEED_123456=https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs
MTA_FEED_ACE=https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs-ace
MTA_FEED_BDFM=https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2Fgtfs-bdfm
MTA_FEED_ALERTS=https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/camsys%2Fsubway-alerts
MTA_BUS_FEED=http://bustime.mta.info/api/siri/vehicle-monitoring.json

# --------------------------------------------------------------
# Polling & performance settings
# POLL_INTERVAL_MS   : how often the server re-fetches feeds (ms)
# STALE_THRESHOLD_MS : age after which cached data is flagged stale (ms)
# FETCH_TIMEOUT_MS   : per-request timeout (ms)
# MAX_RETRIES        : consecutive failures before error state
# --------------------------------------------------------------
POLL_INTERVAL_MS=30000
STALE_THRESHOLD_MS=90000
FETCH_TIMEOUT_MS=10000
MAX_RETRIES=3

# --------------------------------------------------------------
# Server
# --------------------------------------------------------------
PORT=3000
